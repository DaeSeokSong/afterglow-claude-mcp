{
  "name": "@daeseoksong/afterglow-mcp",
  "version": "0.4.0",
  "description": "Afterglow MCP server — manage 퇴사자 에이전트 폴더 + persona + RAG, surfaced as Claude Code slash commands.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "DaeSeokSong (https://github.com/DaeSeokSong)",
  "homepage": "https://github.com/DaeSeokSong/Afterglow/tree/main/server#readme",
  "bugs": {
    "url": "https://github.com/DaeSeokSong/Afterglow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaeSeokSong/Afterglow.git",
    "directory": "server"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "anthropic",
    "afterglow",
    "agent",
    "persona",
    "rag",
    "offboarding"
  ],
  "bin": {
    "afterglow-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:stdio": "node test/stdio.smoke.mjs",
    "test:all": "npm run test && npm run build && npm run test:stdio",
    "prepublishOnly": "npm run build && npm run test && npm run test:stdio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
